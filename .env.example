# Copy this file to backend/.env and fill in real values.


# Database
MONGO_URI=your_mongodb_connection_string

# Server
PORT=5000
NODE_ENV=production

# Auth
JWT_SECRET=your_jwt_secret_min_32_chars

# Frontend / CORS (production origin)
FRONTEND_URL=https://yourdomain.com

# Email (password reset & contact form)
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# External APIs
USDA_API_KEY=your_usda_food_data_api_key
NINJA_API_KEY=your_api_ninjas_exercise_api_key

# AI — Groq (production)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama3-8b-8192

# AI — Ollama (development)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3:latest

# VITE_API_URL=https://api.yourdomain.com
